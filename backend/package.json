{
  "name": "admin-web-fitness-backend",
  "version": "1.0.0",
  "description": "Backend for admin web fitness",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:integration": "jest src/tests/unit/integration",
    "prisma:generate:main": "npx prisma generate --schema=prisma/schema.postgres.prisma",
    "prisma:migrate:main": "npx prisma migrate deploy --schema=prisma/schema.postgres.prisma",
    "prisma:generate:admin": "npx prisma generate --schema=prisma/schema.admin.prisma",
    "prisma:migrate:admin": "npx prisma migrate deploy --schema=prisma/schema.admin.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "argon2": "^0.44.0",
    "axios": "^1.13.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.2.1",
    "generate-password": "^1.7.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.18.0",
    "react-router": "^7.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.3.1",
    "jest": "^30.3.0",
    "prisma": "^5.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
