generator client {
  provider = "prisma-client-js"
  output   = "../prisma-client-admin"
}

datasource db {
  provider = "postgresql"
}

model admins {
  id       Int     @id @default(autoincrement())
  email    String  @unique @db.VarChar
  password String  @db.VarChar
  masterid Boolean @default(false)
}
